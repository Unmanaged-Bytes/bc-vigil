BC_VIGIL_HOST=0.0.0.0
BC_VIGIL_PORT=8080
BC_VIGIL_DATA_DIR=/var/lib/bc-vigil
BC_VIGIL_BC_HASH_BINARY=bc-hash
BC_VIGIL_BC_DUPLICATE_BINARY=bc-duplicate
BC_VIGIL_DEFAULT_ALGORITHM=sha256
BC_VIGIL_DEFAULT_THREADS=auto
BC_VIGIL_MAX_PARALLEL_SCANS=2
BC_VIGIL_DISPLAY_TZ=UTC
BC_VIGIL_SCAN_RETENTION_DAYS=0
# Empty = <data_dir>/dedup/trash; set to point at a disk with more room.
BC_VIGIL_DEDUP_TRASH_DIR=
BC_VIGIL_DEDUP_TRASH_RETENTION_DAYS=7
BC_VIGIL_DEDUP_DELETION_BULK_THRESHOLD=500
